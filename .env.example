# --- LockedIn environment variables ---

# Google Gemini API key — powers the AI Coach + build-in-public post generator.
# FREE tier, no credit card: https://aistudio.google.com/apikey
# The app runs fine WITHOUT this (the Coach shows an "add your API key" message
# instead of crashing); the AI features stay disabled until you set it.
GEMINI_API_KEY=

# Optional: which Gemini model to use. Defaults to gemini-2.5-flash if unset.
# (gemini-2.5-flash is on the free tier; 1.5-flash is retired.)
GEMINI_MODEL=gemini-2.5-flash

# --- AI provider ---
# "ollama" = local model (free, private, no tokens) · "gemini" = cloud.
# Leave unset: the desktop app uses ollama, the web build uses gemini.
# AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- LOGIN (password gate) ---
# Set APP_PASSWORD to turn on the login gate (whole app becomes private).
# Leave it BLANK to disable the gate entirely (app is open).
# AUTH_SECRET signs the login cookie — set it to any long random string.
APP_PASSWORD=
AUTH_SECRET=change-me-to-a-long-random-string

# Your timezone — "today" is computed in this zone everywhere (local + Vercel),
# so day buckets/streaks match no matter where the app runs. Use an IANA name.
APP_TZ=Asia/Kolkata

# SQLite database location (relative to /prisma). Leave as-is for local dev.
DATABASE_URL="file:./dev.db"

# --- PRODUCTION ONLY (Turso hosted SQLite) ---
# Leave these BLANK for local dev — the app uses the local file above.
# On Vercel, set both and the app switches to Turso automatically.
# Create a DB: `turso db create lockedin` then `turso db show --url lockedin`
# and `turso db tokens create lockedin`.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

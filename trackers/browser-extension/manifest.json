{
  "manifest_version": 3,
  "name": "LockedIn — YouTube Tracker",
  "version": "0.1.0",
  "description": "Sends your YouTube watch time to LockedIn's /api/track endpoint.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://locked-in-cyan.vercel.app/*",
    "https://*.youtube.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "options_ui": { "page": "options.html", "open_in_tab": false }
}
